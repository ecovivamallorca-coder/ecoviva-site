<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EcoViva Intake</title>

<style>
body {
  margin:0;
  font-family: Inter, sans-serif;
  background: linear-gradient(180deg,#07101b,#0d1828);
  color:#fff;
}

.container {
  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

.hero {
  background: linear-gradient(135deg,#0c1829,#0a1422);
  padding:50px;
  border-radius:24px;
}

.hero h1 {
  font-size:42px;
}

.hero p {
  color:#cdd7e6;
  max-width:600px;
}

.cta {
  margin-top:25px;
}

.cta button {
  background:#8fde65;
  border:none;
  padding:14px 26px;
  border-radius:10px;
  font-size:16px;
  cursor:pointer;
}

/* MODAL backdrop */
.modal-bg {
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.7);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:999;
}

/* MODAL box */
.modal {
  width:90%;
  max-width:900px;
  background:#fff;
  border-radius:20px;
  overflow:hidden;
}

/* CLOSE */
.close {
  position:absolute;
  top:20px;
  right:30px;
  font-size:22px;
  cursor:pointer;
  color:#fff;
}
</style>
</head>

<body>

<div class="container">

  <div class="hero">
    <h1>Private property & project advisory intake</h1>
    <p>
      For renovation, technical consulting and partner collaboration.
    </p>

    <div class="cta">
      <button onclick="openModal()">Start intake</button>
    </div>
  </div>

</div>

<div class="modal-bg" id="modal">
  <div class="close" onclick="closeModal()">✕</div>

  <div class="modal">
    <div
      data-fillout-id="59qsbh9ckrus"
      data-fillout-embed-type="popup"
      data-fillout-popup-size="large">
    </div>
  </div>
</div>

<script src="https://server.fillout.com/embed/v1/"></script>

<script>
function openModal(){
  document.getElementById("modal").style.display="flex";
}

function closeModal(){
  document.getElementById("modal").style.display="none";
}
</script>

</body>
</html>
